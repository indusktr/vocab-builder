{
  "manifest_version": 3,
  "name": "Vocab Builder",
  "version": "5.1.1",
  "description": "Build your personal vocabulary hub. Highlight, save, and master new words directly from any webpage as you browse.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}