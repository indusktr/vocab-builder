{
  "manifest_version": 3,
  "name": "Vocab Builder - Build Your Vocabulary Seamlessly",
  "version": "5.3.1",
  "description": "Highlight words while reading and save them to Chrome's new tab for natural vocabulary building.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}